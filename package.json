{
  "name": "tradingview2claude-connector",
  "version": "2.0.0",
  "description": "TradingView2Claude Connector — Analisi AI del mercato in tempo reale",
  "author": "TradingView2Claude",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dist-win": "electron-builder --win"
  },
  "build": {
    "appId": "com.tv2claude.connector",
    "productName": "TradingView2Claude Connector",
    "copyright": "TradingView2Claude Connector",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "assets/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "assets/icon.ico",
      "artifactName": "TradingView2Claude-Setup-${version}.exe"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "TradingView2Claude Connector"
    },
    "extraResources": [
      { "from": "bundled-mcp",  "to": "bundled-mcp" },
      { "from": "bundled-node", "to": "bundled-node" }
    ]
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  }
}
